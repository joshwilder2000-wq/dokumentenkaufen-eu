# Dokuments Hub - Apache Configuration
# Performance Optimized Version for Mobile

# Enable rewrite engine
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Redirect to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ===== Specific product redirects to mikibucherbox.de =====
RewriteRule ^product/bachelor-kaufen(/|\.html)?$ https://mikibucherbox.de/m/bachelor-zertifikat/ [L,R=301]
RewriteRule ^product/iu-fernuniversitaet-zertifikat(/|\.html)?$ https://mikibucherbox.de/m/iu-fernuniversitaet-zertifikat/ [L,R=301]
RewriteRule ^product/fom-urkunde(/|\.html)?$ https://mikibucherbox.de/m/fom-urkunde/ [L,R=301]
RewriteRule ^product/fh-urkunde(/|\.html)?$ https://mikibucherbox.de/m/euro-fh/ [L,R=301]

# ===== Trailing-slash → .html redirects (WordPress URL compatibility) =====
# Google indexed the old WordPress URLs (/product/slug/, /blog/slug/).
# Redirect them to our static .html files with 301 so the index updates.
# IMPORTANT: only match slugs WITHOUT a dot (so real .html requests are untouched).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^product/([^/.]+)/?$ /product/$1.html [L,R=301]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^category/([^/.]+)/?$ /category/$1.html [L,R=301]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/.]+)/?$ /blog/$1.html [L,R=301]
# Tag pages (trailing-slash → .html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^tag/([^/.]+)/?$ /tag/$1.html [L,R=301]
# Root-level pages (e.g. /agb/ → /agb.html) — only if no dot in the name
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/.]+)/$ /$1.html [L,R=301]

# ===== Special-case: sachkundeprufung URL variants =====
# The § sign (encoded as %C2%A7) appears in Google's indexed URL but our file has no §
RewriteRule ^product/sachkundeprufung-nach-.*34a/?$ /product/sachkundeprufung-nach-34a.html [L,R=301]
RewriteRule ^product/sachkundeprufung-nach-.*34a\.html$ /product/sachkundeprufung-nach-34a.html [L]

# Compatibility for older extensionless product image URL.
RewriteRule ^images/products/sachkundeprufung$ /images/products/sachkundeprufung%20nach%2034a.webp [R=301,L]

# Custom error pages
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html
</IfModule>

# Enable compression - AGGRESSIVE for mobile
<IfModule mod_deflate.c>
# Compress all text content
AddOutputFilterByType DEFLATE text/html text/plain text/xml application/xml text/css text/javascript application/javascript application/json application/font-woff2 font/woff2

# Also compress by file extension
<FilesMatch "\.(html|htm|css|js|json|xml|txt)$">
    SetOutputFilter DEFLATE
</FilesMatch>

# Highest compression level
DeflateCompressionLevel 9

# Don't compress images (already compressed)
SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|svgz)$ no-gzip dont-vary
</IfModule>

# Force XML files to be served with correct MIME type
<IfModule mod_mime.c>
AddType application/xml .xml
AddType text/xml .xml
AddType image/webp .webp
AddType font/woff2 .woff2
</IfModule>

# Browser caching - OPTIMIZED FOR MOBILE
<IfModule mod_expires.c>
ExpiresActive On

# Images - 1 year (long cache for mobile data savings)
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType image/x-icon "access plus 1 year"

# CSS and JavaScript - 1 year (versioned files)
ExpiresByType text/css "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"

# Fonts - 1 year
ExpiresByType font/woff2 "access plus 1 year"
ExpiresByType font/woff "access plus 1 year"
ExpiresByType font/ttf "access plus 1 year"
ExpiresByType application/font-woff2 "access plus 1 year"

# HTML - 1 day only (content changes)
ExpiresByType text/html "access plus 1 day"
ExpiresByType text/xml "access plus 1 day"
ExpiresByType application/xml "access plus 1 day"

# JSON - 1 day
ExpiresByType application/json "access plus 1 day"
</IfModule>

# Cache-Control headers for better browser caching
<IfModule mod_headers.c>
# Set Cache-Control for images - immutable for versioned assets
<FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Set Cache-Control for CSS and JS
<FilesMatch "\.(css|js)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Set Cache-Control for fonts
<FilesMatch "\.(woff2|woff|ttf)$">
Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Security headers
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Performance headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-DNS-Prefetch-Control "on"

# Remove X-Powered-By header for security
Header always unset X-Powered-By

# Enable Keep-Alive
Header set Connection keep-alive

# Add Vary header for compression
Header append Vary Accept-Encoding
</IfModule>

# Enable Keep-Alive for persistent connections
<IfModule mod_headers.c>
Header set Connection keep-alive
</IfModule>

# ETags for caching (if not using filename-based cache busting)
<IfModule mod_headers.c>
Header unset ETag
</IfModule>
FileETag None

# Serve WebP images with correct MIME type
AddType image/webp .webp

# Allow access to sitemap
<Files "sitemap.xml">
    Order allow,deny
    Allow from all
</Files>

# Allow access to all sitemap files
<FilesMatch "^sitemap.*\.xml$">
    Order allow,deny
    Allow from all
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
Order allow,deny
Deny from all
</FilesMatch>

<FilesMatch "\.(md|log|ini)$">
Order allow,deny
Deny from all
</FilesMatch>

# Protect the SQLite database (CMS backend) and data directory.
<FilesMatch "\.(sqlite|sqlite3|db)$">
Order allow,deny
Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
RewriteRule ^data/ - [F,L]
</IfModule>

# Mobile optimization: Disable ETags to reduce header size
<IfModule mod_headers.c>
Header unset ETag
</IfModule>
FileETag None
